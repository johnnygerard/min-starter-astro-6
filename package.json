{
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^13.3.0",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.2.1",
    "clsx": "^2.1.1",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "onFail": "warn",
      "version": "11"
    },
    "runtime": {
      "name": "node",
      "onFail": "warn",
      "version": "24"
    }
  },
  "name": "starter-astro-6",
  "private": true,
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "cf-typegen": "wrangler types",
    "check": "tsc --noEmit && astro check",
    "check:deploy": "wrangler deploy --outdir dist --dry-run",
    "dev": "astro dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "astro preview --port 3321",
    "pw": "playwright",
    "pw:test": "playwright test",
    "qa": "npm run build && npm run check && npm run format:check && npm test && npm run pw:test",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "wg": "wrangler"
  },
  "type": "module",
  "version": "0.0.0"
}
