{
  "dependencies": {
    "@astrojs/cloudflare": "^13.3.0",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "onFail": "warn",
      "version": "11"
    },
    "runtime": {
      "name": "node",
      "onFail": "warn",
      "version": "24"
    }
  },
  "name": "min-starter-astro-6",
  "private": true,
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "check:deploy": "wrangler deploy --outdir dist --dry-run",
    "dev": "astro dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "astro preview --port 3321",
    "pw": "playwright",
    "pw:test": "playwright test",
    "qa": "npm run build && npm run format:check && npm test && npm run pw:test",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "wg": "wrangler"
  },
  "type": "module",
  "version": "0.0.0"
}
