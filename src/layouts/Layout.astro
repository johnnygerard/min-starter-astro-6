---
import { Font } from "astro:assets";
import Favicon from "~/components/Favicon.astro";
import "~/styles/globals.css";

type Props = {
  title: string;
  description: string;
  indexed?: boolean;
};

const { title, description, indexed = true } = Astro.props;
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="utf-8" />
    <Font cssVariable="--font-geist" preload />
    <Favicon />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {
      /* Bing: https://www.bing.com/webmasters/help/robots-meta-tags-and-attributes-that-bing-supports-5198d240 */
      /* Google: https://developers.google.com/search/docs/crawling-indexing/robots-meta-tag#directives */
    }
    {!indexed && <meta name="robots" content="noindex" />}
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    {/* This wrapper prevents a body overflow in mobile browsers. */}
    <div>
      {/* <Header /> */}
      <main>
        <slot />
      </main>
      {/* <Footer /> */}
    </div>
  </body>
</html>
